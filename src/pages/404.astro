---
import BaseLayout from "../components/BaseLayout.astro";
---

<BaseLayout title="404 — Page Not Found" noindex={true}>
  <section class="py-16 lg:py-24 animate-fade-in">
    <div class="container mx-auto">

      <div class="sys-strip mb-12 lg:mb-16">
        <span class="sys-key">~/404</span>
        <span class="sys-dot">●</span>
        <span class="sys-value">status: not_found</span>
        <span class="sys-dot">●</span>
        <span class="sys-value">code: 0x194</span>
        <span class="sys-dot">●</span>
        <span class="sys-value ml-auto">retry: manual</span>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-14 items-end mb-16 lg:mb-24">
        <div class="lg:col-span-7">
          <div class="kicker mb-6">/error · stack underflow</div>
          <h1 class="marquee-title text-[28vw] sm:text-[24vw] md:text-[20vw] lg:text-[18vw] leading-[0.85]">
            <span class="text-app-text">4</span><span class="text-app-accent">0</span><span class="text-app-text">4</span><span class="text-app-accent-2">.</span>
          </h1>
        </div>
        <div class="lg:col-span-5">
          <h2 class="font-display text-2xl md:text-3xl lg:text-4xl text-app-text tracking-tight leading-[1.1] mb-4">
            This page is<br/>
            <span class="font-serif italic font-normal text-app-accent">not in the index</span>.
          </h2>
          <p class="text-base lg:text-lg text-app-gray-500 leading-[1.55] max-w-md mb-8">
            Either the URL is wrong, the page moved, or it never existed. No
            backtrace to follow — just turn back.
          </p>
          <div class="flex flex-wrap gap-3">
            <a href="/" class="btn-primary">
              <span>Back to home</span>
              <span class="font-mono text-xs">←</span>
            </a>
            <a href="/blog/" class="btn-ghost">
              <span class="font-mono text-[11px] uppercase tracking-[0.12em]">Read the blog</span>
              <span>↘</span>
            </a>
          </div>
        </div>
      </div>

      <!-- Helpful map -->
      <div class="border-t border-app-ink-line pt-10">
        <div class="kicker mb-6">/sitemap · try one of these</div>
        <ul class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-px bg-app-border border border-app-border">
          {[
            { label: "Home", href: "/" },
            { label: "Blog", href: "/blog/" },
            { label: "Skills", href: "/skills/" },
            { label: "Projects", href: "/projects/" },
            { label: "Services", href: "/services/" },
            { label: "About", href: "/about/" },
          ].map((l, i) => (
            <li>
              <a
                href={l.href}
                class="group bg-app-body hover:bg-app-text hover:text-app-body transition-colors duration-300 px-5 py-5 flex flex-col justify-between min-h-[88px]"
              >
                <span class="font-mono text-[10px] uppercase tracking-[0.18em] text-app-accent group-hover:text-app-accent-2">
                  /{String(i + 1).padStart(2, "0")} ↗
                </span>
                <span class="font-display text-base font-medium tracking-tight">{l.label}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>
