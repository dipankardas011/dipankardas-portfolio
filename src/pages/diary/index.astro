---
import BaseLayout from "../../components/BaseLayout.astro";
import AnimatedTitle from "../../components/AnimatedTitle.astro";
import { getCollection } from "astro:content";

const entries = (await getCollection("diary")).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const entriesByYear = entries.reduce((acc, entry) => {
  const year = entry.data.date.getFullYear();
  if (!acc[year]) acc[year] = [];
  acc[year].push(entry);
  return acc;
}, {} as Record<number, typeof entries>);

const years = Object.keys(entriesByYear).sort((a, b) => Number(b) - Number(a));
---

<BaseLayout
  title="Diary - Dipankar Das"
  description="Monthly engineering diary entries tracking learnings and activities."
>
  <AnimatedTitle
    title="Diary"
    kicker="/diary · monthly logs"
    subtitle="Notes from the months — what I built, what broke, what I'm reading."
  />

  <section class="py-10 lg:py-16 animate-fade-in">
    <div class="container mx-auto">

      <div class="sys-strip mb-12 lg:mb-16">
        <span class="sys-key">~/diary</span>
        <span class="sys-dot">●</span>
        <span class="sys-value">{entries.length} entries</span>
        <span class="sys-dot">●</span>
        <span class="sys-value">{years.length} years</span>
      </div>

      <div class="max-w-4xl mx-auto">
        {years.map((year) => (
          <div class="mb-16 lg:mb-20">
            <!-- Year heading -->
            <div class="flex items-baseline gap-6 mb-8 lg:mb-10 border-b border-app-ink-line pb-4">
              <span class="font-display text-5xl lg:text-7xl font-medium text-app-text tracking-[-0.04em] leading-none">
                {year}
              </span>
              <span class="font-mono text-[10px] uppercase tracking-[0.18em] text-app-gray-400">
                · {entriesByYear[year].length} entries
              </span>
            </div>

            <!-- Entries -->
            <ul>
              {entriesByYear[year].map((entry) => {
                const month = entry.data.date.toLocaleDateString("en-US", { month: "long" });
                return (
                  <li>
                    <a
                      href={`/diary/${entry.id}/`}
                      class="group grid grid-cols-[7rem_1fr_auto] items-baseline gap-6 lg:gap-10 py-5 border-b border-app-border hover:bg-app-surface transition-colors"
                    >
                      <time class="font-mono text-xs uppercase tracking-[0.16em] text-app-accent-2 self-start mt-1">
                        {month}
                      </time>
                      <div class="min-w-0">
                        <h2 class="font-display text-lg lg:text-2xl text-app-text tracking-tight leading-snug group-hover:text-app-accent transition-colors">
                          {entry.data.title}
                        </h2>
                        {entry.data.description && (
                          <p class="mt-1.5 text-sm lg:text-base text-app-gray-400 leading-[1.5] line-clamp-2">
                            {entry.data.description}
                          </p>
                        )}
                      </div>
                      <span class="font-mono text-xs text-app-gray-400 group-hover:text-app-accent-2 group-hover:translate-x-1 transition-all self-start mt-1">
                        →
                      </span>
                    </a>
                  </li>
                );
              })}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
