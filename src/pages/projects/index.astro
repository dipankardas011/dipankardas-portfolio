---
import BaseLayout from "../../components/BaseLayout.astro";
import AnimatedTitle from "../../components/AnimatedTitle.astro";
import ProjectCard from "../../components/ProjectCard.astro";
import SectionHeader from "../../components/SectionHeader.astro";
import OSSCard from "../../components/OSSCard.astro";
import { projects, ossContributions, categories } from "../../data/projects";
---

<BaseLayout
  title="Projects - Dipankar Das"
  description="Open-source projects, distributed systems, and infrastructure tools."
>
  <AnimatedTitle title="Projects" kicker="/projects · things i've shipped" />

  <section class="py-10 lg:py-16 animate-fade-in">
    <div class="container mx-auto">

      <!-- System strip -->
      <div class="sys-strip mb-10 lg:mb-14">
        <span class="sys-key">~/projects</span>
        <span class="sys-dot">●</span>
        <span class="sys-value">{projects.length} entries</span>
        <span class="sys-dot">●</span>
        <span class="sys-value">{categories.length} categories</span>
        <span class="sys-dot">●</span>
        <span class="sys-value">{ossContributions.length} oss orgs</span>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 mb-16 lg:mb-24">
        <div class="lg:col-span-8">
          <h2 class="font-display text-3xl md:text-5xl lg:text-6xl text-app-text tracking-tight leading-[1.02]">
            Things I've<br/>
            <span class="font-serif italic font-normal text-app-accent">shipped &amp; broken</span>
            in production.
          </h2>
          <p class="mt-8 max-w-xl text-base lg:text-lg text-app-gray-500 leading-[1.55]">
            Tools, systems, and experiments built to solve real-world infrastructure
            problems — not portfolio pieces. Every one of these has shipped or been
            used in anger.
          </p>
        </div>
        <aside class="lg:col-span-4 lg:pl-8 lg:border-l border-app-border flex flex-col justify-end">
          <div class="kicker mb-3">/ledger</div>
          <dl class="grid grid-cols-2 gap-y-3 gap-x-4 font-mono text-[11px] uppercase tracking-[0.14em]">
            <dt class="text-app-gray-400">projects</dt>
            <dd class="text-app-text font-semibold text-right">{projects.length}</dd>
            <dt class="text-app-gray-400">categories</dt>
            <dd class="text-app-text font-semibold text-right">{categories.length}</dd>
            <dt class="text-app-gray-400">oss orgs</dt>
            <dd class="text-app-text font-semibold text-right">{ossContributions.length}</dd>
            <dt class="text-app-gray-400">prs merged</dt>
            <dd class="text-app-accent font-semibold text-right">{ossContributions.reduce((a, c) => a + c.prs.length, 0)}+</dd>
          </dl>
        </aside>
      </div>

      {categories.map((cat, catIndex) => {
        const catProjects = projects.filter((p) => p.category === cat);
        if (catProjects.length === 0) return null;
        return (
          <div class="mb-20 lg:mb-28">
            <SectionHeader
              title={cat}
              index={catIndex + 1}
              kicker={`category · ${catProjects.length} ${catProjects.length === 1 ? "entry" : "entries"}`}
              className="mb-8 lg:mb-12"
            />
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
              {catProjects.map((p) => (
                <ProjectCard
                  title={p.title}
                  description={p.description}
                  image={p.image}
                  links={p.links}
                  tags={p.tags}
                />
              ))}
            </div>
          </div>
        );
      })}

      <!-- OSS Contributions -->
      <div class="border-t border-app-ink-line pt-14 lg:pt-20">
        <SectionHeader
          title="Open source contributions"
          kicker="upstream · oss"
          index={categories.length + 1}
          subtitle="Pull requests merged into CNCF and other community projects."
          className="mb-10 lg:mb-12"
        />
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8">
          {ossContributions.map((c) => (
            <OSSCard org={c.org} prs={c.prs} />
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
