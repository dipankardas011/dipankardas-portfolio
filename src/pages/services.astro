---
import BaseLayout from "../components/BaseLayout.astro";
import AnimatedTitle from "../components/AnimatedTitle.astro";
import ServiceCard from "../components/ServiceCard.astro";
import CertBadge from "../components/CertBadge.astro";
import ContactSection from "../components/ContactSection.astro";
import DirectBooking from "../components/DirectBooking.astro";
import SectionHeader from "../components/SectionHeader.astro";
import { services, certifications } from "../data/services";
import { siteConfig } from "../data/site";
---

<BaseLayout
  title="Services - Dipankar Das"
  description="DevOps consulting, Kubernetes expertise, Go development, and sustainability engineering."
>
  <AnimatedTitle title="Services" kicker="/services · how i can help" />

  <section class="py-10 lg:py-16 animate-fade-in">
    <div class="container mx-auto">

      <div class="sys-strip mb-10 lg:mb-14">
        <span class="sys-key">~/services</span>
        <span class="sys-dot">●</span>
        <span class="sys-value">{services.length} core offerings</span>
        <span class="sys-dot">●</span>
        <span class="sys-value">availability: open</span>
      </div>

      <p class="text-base lg:text-xl text-app-gray-500 leading-[1.55] max-w-3xl mb-16 lg:mb-24">
        I help teams <span class="font-serif italic text-app-accent">{siteConfig.tagline.toLowerCase()}</span>.
        From Software Development and System Design to DevOps and Cloud-Native infrastructure —
        a focused suite of services to elevate the layer your business runs on.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8 mb-20 lg:mb-28 animate-stagger">
        {services.map((s) => (
          <ServiceCard
            title={s.title}
            abbreviation={s.abbreviation}
            icon={s.icon}
            description={s.description}
            skills={s.skills}
            color={s.color}
          />
        ))}
      </div>

      <div class="border-t border-app-ink-line pt-14 lg:pt-20">
        <SectionHeader
          title="Certifications & badges"
          kicker="credentials"
          index={services.length + 1}
          subtitle="Industry-recognized proof of work backing the practice."
          className="mb-10 lg:mb-12"
        />
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4 lg:gap-5">
          {certifications.map((cert) => (
            <CertBadge name={cert.name} badgeImage={cert.badgeImage} link={cert.link} />
          ))}
        </div>
      </div>
    </div>
  </section>

  <DirectBooking />
  <ContactSection />
</BaseLayout>
