---
Astro.response.headers.append("Link", `<${Astro.site}skills/>; rel="describes"`);
Astro.response.headers.append("Link", `<${Astro.site}skills/>; rel="http://www.iana.org/assignments/link-relations/api-catalog"`);
Astro.response.headers.append("Link", `<${Astro.site}services/>; rel="service-doc"`);
Astro.response.headers.append("Link", `<${Astro.site}projects/>; rel="describes"`);
Astro.response.headers.append("Link", `<${Astro.site}blog/>; rel="describes"`);
Astro.response.headers.append("Link", `<${Astro.site}about/>; rel="about"`);
Astro.response.headers.append("Link", `<${Astro.site}rss.xml>; rel="alternate"; type="application/rss+xml"`);

import BaseLayout from "../components/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import ServiceCard from "../components/ServiceCard.astro";
import ProjectCard from "../components/ProjectCard.astro";
import ContactSection from "../components/ContactSection.astro";
import SectionHeader from "../components/SectionHeader.astro";
import Testimonials from "../components/Testimonials.astro";
import { services } from "../data/services";
import { projects } from "../data/projects";
import { testimonials } from "../data/testimonials";

const featuredProjects = projects.filter((p) => p.featured);
---

<BaseLayout>
  <Hero />

  <!-- Services -->
  <section class="py-16 lg:py-24 border-t border-app-ink-line">
    <div class="container mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 mb-10 lg:mb-14">
        <div class="lg:col-span-6">
          <SectionHeader
            title="What I do"
            kicker="services"
            index={1}
            className="mb-0"
          />
        </div>
        <div class="lg:col-span-6 lg:pt-12">
          <p class="text-base lg:text-lg leading-[1.55] text-app-gray-500 max-w-xl">
            Consulting and engineering for modern infrastructure — Software Development,
            DevOps, cloud-native systems, and sustainable computing.
          </p>
        </div>
      </div>
      <ul class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8 animate-stagger">
        {services.map((s) => (
          <li>
            <ServiceCard
              title={s.title}
              abbreviation={s.abbreviation}
              icon={s.icon}
              description={s.description}
              skills={s.skills}
              color={s.color}
            />
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Testimonials -->
  <Testimonials testimonials={testimonials} />

  <!-- Featured Projects -->
  <section class="py-16 lg:py-24 border-t border-app-ink-line">
    <div class="container mx-auto">
      <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 mb-10 lg:mb-12">
        <SectionHeader
          title="Featured projects"
          kicker="oss · tools"
          index={2}
          subtitle="Open-source tools and systems I've built and shipped."
          className="mb-0"
        />
        <a href="/projects/" class="btn-ghost shrink-0">
          <span class="font-mono text-[11px] uppercase tracking-[0.12em]">View all</span>
          <span>→</span>
        </a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8 animate-stagger">
        {featuredProjects.map((p) => (
          <ProjectCard
            title={p.title}
            description={p.description}
            image={p.image}
            links={p.links}
            tags={p.tags}
          />
        ))}
      </div>
    </div>
  </section>

  <ContactSection />
</BaseLayout>
