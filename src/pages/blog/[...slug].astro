---
import BaseLayout from "../../components/BaseLayout.astro";
import BlogPostCard from "../../components/BlogPostCard.astro";
import TopGradient from "../../components/TopGradient.astro";
import { getCollection, render } from "astro:content";
import { siteConfig, socialLinks } from "../../data/site";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  return posts
    .filter((p) => p.id !== "external-blogs")
    .map((post) => ({
      params: { slug: post.id },
      props: { post },
    }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

// ---- Table of Contents data ----
const tocHeadings = headings.filter((h) => h.depth <= 3);
let h2Counter = 0;
const tocItems = tocHeadings.map((h) => {
  if (h.depth === 2) h2Counter++;
  return {
    ...h,
    num: h.depth === 2 ? String(h2Counter).padStart(2, "0") : null,
  };
});

const allPosts = (await getCollection("blog", ({ data }) => !data.draft))
  .filter((p) => p.id !== "external-blogs" && p.id !== post.id)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const formattedDate = post.data.date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const wordCount = post.body.trim().split(/\s+/).length;
const readingTime = Math.max(1, Math.ceil(wordCount / 200));
---

<BaseLayout
  title={`${post.data.title} - Dipankar Das`}
  description={post.data.description}
  ogImage={post.data.cover}
  blogPost={true}
  publishedDate={post.data.date}
  author={post.data.author ?? siteConfig.name}
  tags={post.data.tags}
>
  <!-- Reading progress bar -->
  <div id="reading-progress"></div>

  <article class="animate-fade-in">
    <!-- Header -->
    <div class="relative pt-10 pb-8 md:pt-16 md:pb-12 lg:pt-20 lg:pb-16">
      <TopGradient />
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="mb-8 md:mb-14 lg:mb-20">
          <div class="flex flex-col lg:flex-row lg:items-center lg:gap-14">

            <!-- Left: title, lede, tags, meta -->
            <div class="flex-1 flex flex-col items-center text-center lg:items-start lg:text-left">
              <!-- Title -->
              <h1 class="text-2xl md:text-4xl lg:text-5xl font-display text-app-text leading-tight tracking-[var(--tracking-tight)] mb-4 lg:mb-6">
                {post.data.title}
              </h1>

              <!-- Description lede -->
              {post.data.description && (
                <p class="blog-lede mb-5 lg:mb-6">
                  {post.data.description}
                </p>
              )}

              <!-- Tags below lede -->
              {post.data.tags && post.data.tags.length > 0 && (
                <div class="flex flex-wrap gap-2 mb-5 lg:mb-6 justify-center lg:justify-start">
                  {post.data.tags.map((tag: string) => (
                    <span class="text-xs font-medium px-3 py-1 bg-app-surface rounded-[32px] text-app-gray-500 border border-app-gray-200 tracking-[var(--tracking-tight)]">
                      {tag}
                    </span>
                  ))}
                </div>
              )}

              <!-- Date + reading time -->
              <div class="blog-meta lg:justify-start">
                <time>{formattedDate}</time>
                <span class="blog-meta-divider"></span>
                <span>{readingTime} min read</span>
                <span class="blog-meta-divider"></span>
                <span>{wordCount.toLocaleString()} words</span>
              </div>
            </div>

            <!-- Right: cover image -->
            {post.data.cover && (
              <div class="mt-8 lg:mt-0 lg:w-[44%] shrink-0 aspect-[4/3] rounded-2xl overflow-hidden bg-app-surface">
                <img
                  src={post.data.cover}
                  alt={post.data.title}
                  class="w-full h-full object-cover"
                  loading="eager"
                />
              </div>
            )}
          </div>
        </div>

        <!-- Content + ToC grid -->
        <div class="grid grid-cols-1 xl:grid-cols-[220px_minmax(0,1fr)] gap-12">

          <!-- Sticky ToC (xl+ only) -->
          {tocItems.length > 1 && (
            <aside class="hidden xl:block toc-sidebar">
              <div class="sticky top-24 pt-1">
                <p class="toc-label">On this page</p>
                <nav id="toc-nav" class="toc-nav">
                  {tocItems.map((item) => (
                    <a
                      href={`#${item.slug}`}
                      class={`toc-link${item.depth === 3 ? " toc-h3" : ""}`}
                      data-heading-id={item.slug}
                    >
                      {item.num && <span class="toc-num">{item.num}</span>}
                      {item.text}
                    </a>
                  ))}
                  <div class="toc-indicator" aria-hidden="true"></div>
                </nav>
              </div>
            </aside>
          )}

          <!-- Mobile ToC (below xl) -->
          {tocItems.length > 1 && (
            <div class="block xl:hidden toc-mobile-wrapper">
              <button
                type="button"
                id="toc-mobile-toggle"
                class="toc-mobile-toggle"
                aria-expanded="false"
                aria-controls="toc-mobile"
              >
                <span>On this page</span>
                <svg class="toc-toggle-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <polyline points="6 9 12 15 18 9" />
                </svg>
              </button>
              <nav id="toc-mobile" class="toc-mobile-nav">
                {tocItems.map((item) => (
                  <a
                    href={`#${item.slug}`}
                    class={`toc-link${item.depth === 3 ? " toc-h3" : ""}`}
                    data-heading-id={item.slug}
                  >
                    {item.num && <span class="toc-num">{item.num}</span>}
                    {item.text}
                  </a>
                ))}
              </nav>
            </div>
          )}

          <!-- Main prose -->
          <div>
            <!-- Visual entry divider -->
            <div class="blog-entry-divider" aria-hidden="true">
              <span></span>
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 2L9.09 8.26L2 9.27L7 14.14L5.82 21.02L12 17.77L18.18 21.02L17 14.14L22 9.27L14.91 8.26L12 2Z"/>
              </svg>
              <span></span>
            </div>

            <div class="prose prose-lg">
              <Content />
            </div>

            <!-- Author card -->
            <div class="author-card">
              <img src="/img/profile_bw.webp" alt={siteConfig.name} />
              <div class="author-card-info">
                <p class="author-card-name">{siteConfig.name}</p>
                <p class="author-card-bio">{siteConfig.tagline}</p>
                <div class="author-card-links">
                  <a href={socialLinks.github} target="_blank" rel="noopener" class="author-card-link">GitHub</a>
                  <span style="color: var(--color-app-gray-300)">·</span>
                  <a href={socialLinks.twitter} target="_blank" rel="noopener" class="author-card-link">Twitter</a>
                  <span style="color: var(--color-app-gray-300)">·</span>
                  <a href={socialLinks.linkedin} target="_blank" rel="noopener" class="author-card-link">LinkedIn</a>
                  <span style="color: var(--color-app-gray-300)">·</span>
                  <a href={socialLinks.sponsor} target="_blank" rel="noopener" class="author-card-link author-card-sponsor">
                    <svg class="inline w-3 h-3 mr-0.5 -mt-px" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
                    Sponsor
                  </a>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Other Posts -->
    {allPosts.length > 0 && (
      <div class="container mx-auto px-4 sm:px-6 lg:px-8 pb-16 md:pb-20 lg:pb-24">
        <div class="border-t border-app-gray-200 pt-12 lg:pt-16">
          <div class="flex items-center justify-between mb-8 lg:mb-12">
            <h2 class="text-xl md:text-2xl lg:text-[32px] font-display text-app-text tracking-[var(--tracking-tight)]">
              Other posts
            </h2>
            <a
              href="/blog"
              class="btn-primary hidden md:inline-flex"
            >
              <span class="mr-2">See all posts</span>
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 lg:w-5 lg:h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14"></path>
                <path d="m12 5 7 7-7 7"></path>
              </svg>
            </a>
          </div>
          <div class="grid grid-cols-1 auto-rows-fr gap-6 p-4 border border-app-gray-200 rounded-2xl md:grid-cols-2 lg:grid-cols-3 lg:gap-8 lg:p-8">
            {allPosts.map((otherPost) => (
              <BlogPostCard
                title={otherPost.data.title}
                date={otherPost.data.date}
                description={otherPost.data.description}
                cover={otherPost.data.cover}
                slug={otherPost.id}
                showIcon={true}
              />
            ))}
          </div>
          <div class="mt-8 text-center md:hidden">
            <a
              href="/blog"
              class="btn-primary inline-flex"
            >
              <span class="mr-2">See all posts</span>
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14"></path>
                <path d="m12 5 7 7-7 7"></path>
              </svg>
            </a>
          </div>
        </div>
      </div>
    )}
  </article>
</BaseLayout>

<script>
  // ---- Reading progress bar ----
  const progressBar = document.getElementById("reading-progress");
  if (progressBar) {
    const update = () => {
      const { scrollTop, scrollHeight, clientHeight } = document.documentElement;
      const pct = (scrollTop / (scrollHeight - clientHeight)) * 100;
      progressBar.style.width = Math.min(pct, 100) + "%";
    };
    window.addEventListener("scroll", update, { passive: true });
    update();
  }

  // ---- Table of Contents ----
  const tocNav = document.getElementById("toc-nav");
  const tocLinks = tocNav?.querySelectorAll(".toc-link");
  const tocIndicator = tocNav?.querySelector(".toc-indicator");

  if (tocLinks && tocLinks.length > 0 && tocNav) {
    // ── Smooth scroll on click ──
    tocLinks.forEach((link) => {
      link.addEventListener("click", (e) => {
        e.preventDefault();
        const id = link.getAttribute("href")?.slice(1);
        if (!id) return;
        const target = document.getElementById(id);
        if (target) {
          target.scrollIntoView({ behavior: "smooth", block: "start" });
          history.replaceState(null, "", `#${id}`);
        }
      });
    });

    // ── Collect heading elements matching our TOC links ──
    const headingEls = [];
    tocLinks.forEach((link) => {
      const id = link.dataset.headingId;
      if (id) {
        const el = document.getElementById(id);
        if (el) headingEls.push(el);
      }
    });

    if (headingEls.length > 0) {
      function updateActive() {
        let activeIdx = -1;
        // Find the last heading that's above/before the current scroll
        for (let i = 0; i < headingEls.length; i++) {
          const rect = headingEls[i].getBoundingClientRect();
          if (rect.top <= 120) {
            activeIdx = i;
          }
        }

        tocLinks.forEach((l) => l.classList.remove("toc-active"));
        if (activeIdx >= 0) {
          tocLinks[activeIdx].classList.add("toc-active");
          // Move the indicator
          if (tocIndicator) {
            const activeLink = tocLinks[activeIdx];
            const navRect = tocNav.getBoundingClientRect();
            const linkRect = activeLink.getBoundingClientRect();
            tocIndicator.style.height = `${linkRect.height}px`;
            tocIndicator.style.transform = `translateY(${linkRect.top - navRect.top}px)`;
          }
        }
      }

      updateActive();
      window.addEventListener("scroll", updateActive, { passive: true });
    }
  }

  // ---- Mobile TOC toggle ----
  const tocToggle = document.getElementById("toc-mobile-toggle");
  const tocMobile = document.getElementById("toc-mobile");
  if (tocToggle && tocMobile) {
    tocToggle.addEventListener("click", () => {
      const expanded = tocToggle.getAttribute("aria-expanded") === "true";
      tocToggle.setAttribute("aria-expanded", String(!expanded));
      tocMobile.classList.toggle("toc-mobile-open");
      const icon = tocToggle.querySelector(".toc-toggle-icon");
      if (icon) {
        icon.style.transform = expanded ? "rotate(0deg)" : "rotate(180deg)";
      }
    });

    // Close mobile TOC when clicking a link
    tocMobile.querySelectorAll(".toc-link").forEach((link) => {
      link.addEventListener("click", () => {
        tocToggle.setAttribute("aria-expanded", "false");
        tocMobile.classList.remove("toc-mobile-open");
        const icon = tocToggle.querySelector(".toc-toggle-icon");
        if (icon) icon.style.transform = "rotate(0deg)";
      });
    });
  }

  // ---- Wrap wide tables in a horizontal scroll container ----
  document.querySelectorAll(".prose table").forEach((table) => {
    const parent = table.parentElement;
    if (!parent || parent.classList.contains("table-scroll")) return;
    const wrap = document.createElement("div");
    wrap.className = "table-scroll";
    parent.insertBefore(wrap, table);
    wrap.appendChild(table);
  });

  // ---- Code block language labels ----
  document.querySelectorAll(".prose pre").forEach((pre) => {
    // Shiki sets data-language on pre; fallback to reading the code class
    const lang =
      (pre as HTMLElement).dataset.language ??
      pre.querySelector("code")?.className.match(/language-(\w+)/)?.[1];
    if (lang && lang !== "plaintext" && lang !== "text") {
      (pre as HTMLElement).dataset.lang = lang;
    }
  });
</script>
