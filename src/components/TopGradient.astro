---
interface Props {
  className?: string;
}

const { className = "" } = Astro.props;
---

<div
  class={`absolute -top-12 left-1/2 -translate-x-1/2 -translate-y-1/3 blur-[120px] w-[260px] h-[260px] md:w-[480px] md:h-[480px] rounded-full opacity-40 pointer-events-none ${className}`}
  style="background: radial-gradient(circle, var(--color-app-accent) 0%, transparent 70%);"
  aria-hidden="true"
></div>
