---
import { socialLinks, siteConfig } from "../data/site";

const year = new Date().getFullYear();

const socials = [
  { label: "GitHub",   href: socialLinks.github },
  { label: "Twitter",  href: socialLinks.twitter },
  { label: "GitLab",   href: socialLinks.gitlab },
  { label: "LinkedIn", href: socialLinks.linkedin },
  { label: "Upwork",   href: socialLinks.upwork },
  { label: "Fiverr",   href: socialLinks.fiverr },
];
---

<footer class="border-t border-app-ink-line mt-16 lg:mt-24">
  <div class="container mx-auto py-12 lg:py-16">

    <!-- CTA block -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 pb-10 lg:pb-14 border-b border-app-border">
      <div class="lg:col-span-7">
        <p class="kicker mb-4">/contact · open to work</p>
        <h2 class="font-display text-4xl md:text-5xl lg:text-6xl text-app-text leading-[0.95] tracking-tight">
          Let's build the<br/>
          <span class="font-serif italic font-normal text-app-accent">infrastructure</span>
          your team deserves.
        </h2>
      </div>
      <div class="lg:col-span-5 flex flex-col justify-end gap-3">
        <a
          href={`mailto:${siteConfig.email}`}
          class="btn-primary justify-between w-full lg:max-w-md"
        >
          <span class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4">
              <rect width="20" height="16" x="2" y="4" rx="2"/>
              <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
            </svg>
            <span class="font-mono text-[11px] uppercase tracking-[0.12em]">{siteConfig.email}</span>
          </span>
          <span class="font-mono text-xs">→</span>
        </a>
        <a
          href={socialLinks.linkedin}
          target="_blank"
          rel="noopener"
          class="btn-ghost justify-between w-full lg:max-w-md"
        >
          <span class="font-mono text-[11px] uppercase tracking-[0.12em]">Connect on LinkedIn</span>
          <span class="font-mono text-xs">↗</span>
        </a>
      </div>
    </div>

    <!-- Socials grid -->
    <div class="pt-10 lg:pt-12 grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-px bg-app-border border border-app-border">
      {socials.map((s) => (
        <a
          href={s.href}
          target="_blank"
          rel="noopener"
          class="group bg-app-body hover:bg-app-text hover:text-app-body transition-colors duration-300 px-5 py-5 flex flex-col justify-between min-h-[88px]"
        >
          <span class="font-mono text-[10px] uppercase tracking-[0.18em] text-app-accent-2 group-hover:text-app-accent">
            ↗
          </span>
          <span class="font-display text-base font-medium tracking-tight">{s.label}</span>
        </a>
      ))}
    </div>

    <!-- Bottom row -->
    <div class="pt-8 lg:pt-10 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 font-mono text-[11px] uppercase tracking-[0.14em] text-app-gray-400">
      <span>&copy; {year} · {siteConfig.name}</span>
      <span>built with astro · hosted with care</span>
      <a href="/rss.xml" class="hover:text-app-text transition-colors">RSS</a>
    </div>
  </div>
</footer>
