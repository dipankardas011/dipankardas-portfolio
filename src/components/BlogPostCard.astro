---
interface Props {
  title: string;
  date: Date;
  description?: string;
  cover?: string;
  slug?: string;
  href?: string;
  featured?: boolean;
  showIcon?: boolean;
}

const { title, date, description, cover, slug, href, featured = false, showIcon = true } = Astro.props;

const link = href || `/blog/${slug}/`;
const formattedDate = date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "short",
  day: "numeric",
}).toUpperCase();
---

<a href={link} target={href ? "_blank" : undefined} rel={href ? "noopener" : undefined} class="block group h-full">
  <article class:list={[
    "h-full flex flex-col transition-transform duration-300 group-hover:-translate-y-1",
    featured && "md:col-span-2 lg:col-span-3"
  ]}>
    {cover && (
      <div class:list={[
        "bg-app-surface overflow-hidden mb-4 lg:mb-5 border border-app-border",
        featured ? "aspect-[2.07] lg:aspect-[2.43]" : "aspect-[1.48] xl:aspect-[1.04]"
      ]}>
        <img
          src={cover}
          alt={title}
          class="w-full h-full object-cover group-hover:scale-[1.04] transition-transform duration-700"
          loading="lazy"
        />
      </div>
    )}
    <div class="flex-1 flex flex-col">
      <time class="font-mono text-[10px] lg:text-[11px] tracking-[0.16em] text-app-accent-2 mb-2 lg:mb-3">
        {formattedDate}
      </time>
      <div class="flex items-start gap-2 mb-2.5 lg:mb-4">
        <h3 class:list={[
          "font-display text-app-text tracking-tight flex-1 group-hover:text-app-accent transition-colors",
          featured ? "text-xl lg:text-3xl leading-[1.1]" : "text-base lg:text-xl leading-[1.2]"
        ]}>
          {title}
        </h3>
        {showIcon && (
          <span class="font-mono text-xs text-app-gray-400 group-hover:text-app-accent-2 transition-colors mt-1">↗</span>
        )}
      </div>
      {description && (
        <p class:list={[
          "text-app-gray-500 leading-[1.5] line-clamp-3",
          featured ? "text-base lg:text-lg" : "text-sm"
        ]}>
          {description}
        </p>
      )}
    </div>
  </article>
</a>
