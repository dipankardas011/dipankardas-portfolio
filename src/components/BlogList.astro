---
interface SerializedPost {
  id: string;
  title: string;
  date: string;
  description?: string;
  cover?: string;
}

interface Props {
  posts: SerializedPost[];
}

const { posts } = Astro.props;
---

<section class="container mx-auto px-4 sm:px-6 lg:px-8 mb-16 md:mb-20 lg:mb-24">
  <div class="flex items-baseline justify-between mb-8 lg:mb-10">
    <h2 class="font-display text-2xl md:text-3xl lg:text-4xl text-app-text tracking-tight">
      All posts
    </h2>
    <span class="font-mono text-[10px] uppercase tracking-[0.18em] text-app-gray-400">
      [{String(posts.length).padStart(2, "0")} entries]
    </span>
  </div>
  <div class="grid grid-cols-1 auto-rows-fr gap-x-8 gap-y-10 md:grid-cols-2 lg:grid-cols-3">
    {posts.map((post) => (
      <a href={`/blog/${post.id}/`} class="block group h-full">
        <article class="h-full flex flex-col transition-transform duration-300 group-hover:-translate-y-1">
          {post.cover && (
            <div class="bg-app-surface overflow-hidden mb-4 aspect-[1.48] xl:aspect-[1.04] border border-app-border">
              <img src={post.cover} alt={post.title} class="w-full h-full object-cover group-hover:scale-[1.04] transition-transform duration-700" loading="lazy" />
            </div>
          )}
          <div class="flex-1 flex flex-col">
            <time class="font-mono text-[10px] tracking-[0.16em] text-app-accent-2 mb-2">
              {new Date(post.date).toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" }).toUpperCase()}
            </time>
            <div class="flex items-start gap-2 mb-3">
              <h3 class="font-display text-app-text leading-[1.2] tracking-tight flex-1 text-lg lg:text-xl group-hover:text-app-accent transition-colors">
                {post.title}
              </h3>
              <span class="font-mono text-xs text-app-gray-400 group-hover:text-app-accent-2 transition-colors mt-1">↗</span>
            </div>
            {post.description && (
              <p class="text-app-gray-500 leading-[1.5] line-clamp-3 text-sm">
                {post.description}
              </p>
            )}
          </div>
        </article>
      </a>
    ))}
  </div>
</section>
