---
interface SerializedPost {
  id: string;
  title: string;
  date: string;
  description?: string;
  cover?: string;
}

interface Props {
  posts: SerializedPost[];
}

const { posts } = Astro.props;
---

<section class="container mx-auto px-4 sm:px-6 lg:px-8 mb-8 md:mb-20 lg:mb-24">
  <div>
    <h2 class="text-xl md:text-2xl lg:text-[32px] font-display text-app-text mb-6 lg:mb-10 tracking-[var(--tracking-tight)]">
      All posts
    </h2>
    <div class="grid grid-cols-1 auto-rows-fr gap-6 p-4 border border-app-gray-200 rounded-2xl md:grid-cols-2 lg:grid-cols-3 lg:gap-8 lg:p-8">
      {posts.map((post) => (
        <a href={`/blog/${post.id}/`} class="block group h-full">
          <article class="h-full flex flex-col overflow-hidden transition-transform duration-300 group-hover:-translate-y-1">
            {post.cover && (
              <div class="bg-app-surface overflow-hidden rounded-2xl mb-4 lg:mb-6 aspect-[1.48] xl:aspect-[1.04]">
                <img src={post.cover} alt={post.title} class="w-full h-full object-cover" loading="lazy" />
              </div>
            )}
            <div class="flex-1 flex flex-col">
              <time class="text-xs lg:text-base font-medium text-app-gray-400 tracking-[var(--tracking-tight)] mb-2 lg:mb-4">
                {new Date(post.date).toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
              </time>
              <div class="flex items-start gap-2 mb-2.5 lg:mb-4">
                <h3 class="font-display text-app-text leading-none tracking-[var(--tracking-tight)] flex-1 text-sm lg:text-2xl">
                  {post.title}
                </h3>
                <div class="flex items-center justify-center p-0.5 lg:p-1 rounded bg-app-surface-alt flex-shrink-0 mt-0.5">
                  <svg class="w-3 h-3 lg:w-4 lg:h-4 text-app-gray-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M7 7h10v10"></path>
                    <path d="M7 17 17 7"></path>
                  </svg>
                </div>
              </div>
              {post.description && (
                <p class="text-app-gray-500 leading-[1.3] tracking-[var(--tracking-tight)] line-clamp-3 text-sm lg:text-xl">
                  {post.description}
                </p>
              )}
            </div>
          </article>
        </a>
      ))}
    </div>
  </div>
</section>