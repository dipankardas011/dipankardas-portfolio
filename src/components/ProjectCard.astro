---
interface Props {
  title: string;
  description: string;
  image?: string;
  links: { label: string; url: string }[];
  tags: string[];
}

const { title, description, image, links, tags } = Astro.props;
---

<article class="group flex flex-col bg-app-body border border-app-border overflow-hidden card-hover">
  {image && (
    <div class="aspect-[1.5] bg-app-surface overflow-hidden border-b border-app-border relative">
      <img
        src={image}
        alt={title}
        class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.04]"
        loading="lazy"
      />
      <span class="absolute top-3 left-3 font-mono text-[10px] uppercase tracking-[0.16em] px-2 py-1 bg-app-body/85 backdrop-blur-sm border border-app-border text-app-gray-500">
        proj
      </span>
    </div>
  )}
  <div class="flex flex-col flex-1 p-5 lg:p-6">
    <h3 class="font-display text-lg lg:text-xl text-app-text tracking-tight mb-2 group-hover:text-app-accent transition-colors">
      {title}
    </h3>
    <p class="text-sm text-app-gray-500 leading-[1.55] mb-5 line-clamp-3">
      {description}
    </p>

    <ul class="flex flex-wrap gap-x-2.5 gap-y-1 font-mono text-[10px] uppercase tracking-[0.14em] text-app-gray-400 mb-5">
      {tags.map((t, i) => (
        <li>
          {i > 0 && <span class="text-app-accent-2 mr-2.5">·</span>}
          {t}
        </li>
      ))}
    </ul>

    <div class="mt-auto pt-4 border-t border-dashed border-app-border flex flex-wrap gap-x-4 gap-y-1">
      {links.map((link) => (
        <a
          href={link.url}
          target="_blank"
          rel="noopener"
          class="link-underline font-mono text-[11px] uppercase tracking-[0.14em] font-medium text-app-text hover:text-app-accent-2 transition-colors"
        >
          {link.label} ↗
        </a>
      ))}
    </div>
  </div>
</article>
