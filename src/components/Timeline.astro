---
import type { Experience } from "../data/about";

interface Props {
  experiences: Experience[];
}

const { experiences } = Astro.props;
---

<div class="relative">
  <!-- Vertical rule -->
  <div class="absolute left-[7px] top-2 bottom-2 w-px bg-app-ink-line hidden md:block"></div>

  <div class="space-y-10 lg:space-y-14">
    {experiences.map((exp, idx) => (
      <article class="relative md:pl-12 group">
        <!-- Marker -->
        <div class="absolute left-0 top-1.5 w-4 h-4 hidden md:flex items-center justify-center">
          <span class="absolute inset-0 bg-app-body"></span>
          <span class="relative w-3 h-3 border border-app-text bg-app-body group-hover:bg-app-accent-2 group-hover:border-app-accent-2 transition-colors"></span>
        </div>

        <div class="border border-app-border bg-app-body">
          <!-- Header bar -->
          <header class="flex items-center justify-between gap-4 px-5 lg:px-6 py-3 border-b border-app-border bg-app-surface">
            <span class="font-mono text-[10px] uppercase tracking-[0.18em] text-app-accent-2">
              {String(idx + 1).padStart(2, "0")} / {String(experiences.length).padStart(2, "0")}
            </span>
            <span class="font-mono text-[10px] uppercase tracking-[0.16em] text-app-gray-400">
              {exp.tenure}
            </span>
          </header>

          <div class="p-5 lg:p-6">
            <div class="flex items-start gap-4 mb-5">
              {exp.logo && (
                <img
                  src={exp.logo}
                  alt={exp.company}
                  class="w-12 h-12 lg:w-14 lg:h-14 object-contain bg-app-surface border border-app-border p-2 flex-shrink-0"
                  loading="lazy"
                />
              )}
              <div class="flex-1 min-w-0">
                <h3 class="font-display text-lg lg:text-xl text-app-text tracking-tight leading-tight mb-1">
                  {exp.link ? (
                    <a href={exp.link} target="_blank" rel="noopener" class="hover:text-app-accent transition-colors">
                      {exp.company}
                      <span class="font-mono text-[10px] text-app-gray-400 ml-1.5 align-middle">↗</span>
                    </a>
                  ) : (
                    exp.company
                  )}
                </h3>
                <p class="font-serif italic text-base text-app-accent">{exp.role}</p>
              </div>
            </div>

            <ol class="space-y-5 lg:space-y-6">
              {exp.contributions.map((c, ci) => (
                <li class="border-l-2 border-app-accent-2/30 pl-4 hover:border-app-accent-2 transition-colors">
                  <div class="flex items-baseline gap-2 mb-2">
                    <span class="font-mono text-[10px] text-app-accent-2 font-semibold tracking-[0.14em]">
                      .{String(ci + 1).padStart(2, "0")}
                    </span>
                    <p class="font-display text-sm lg:text-base font-medium text-app-text tracking-tight leading-snug">
                      {c.title}
                    </p>
                  </div>
                  <dl class="space-y-1.5 text-sm">
                    <div class="flex gap-3">
                      <dt class="font-mono text-[10px] uppercase tracking-[0.18em] text-app-gray-300 shrink-0 min-w-[3rem] mt-[3px]">why</dt>
                      <dd class="text-app-gray-500 leading-[1.55] flex-1">{c.why}</dd>
                    </div>
                    <div class="flex gap-3">
                      <dt class="font-mono text-[10px] uppercase tracking-[0.18em] text-app-gray-300 shrink-0 min-w-[3rem] mt-[3px]">what</dt>
                      <dd class="text-app-gray-500 leading-[1.55] flex-1">{c.what}</dd>
                    </div>
                    <div class="flex gap-3">
                      <dt class="font-mono text-[10px] uppercase tracking-[0.18em] text-app-gray-300 shrink-0 min-w-[3rem] mt-[3px]">how</dt>
                      <dd class="text-app-gray-500 leading-[1.55] flex-1">{c.how}</dd>
                    </div>
                  </dl>
                </li>
              ))}
            </ol>
          </div>
        </div>
      </article>
    ))}
  </div>
</div>
