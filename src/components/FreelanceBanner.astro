---
import { socialLinks } from "../data/site";
---

<section class="py-10 lg:py-14">
  <div class="container mx-auto">
    <div class="bg-app-surface-alt border border-app-gray-100 rounded-2xl px-8 py-10 lg:px-14 lg:py-12">
      <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-8">

        <!-- Left: Headline -->
        <div class="flex-1">
          <div class="flex items-center gap-2 mb-3">
            <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
            <span class="text-sm text-app-gray-400 tracking-[var(--tracking-tight)]">Available for freelance</span>
          </div>
          <p class="text-3xl lg:text-[40px] font-display text-app-text leading-tight lg:leading-none tracking-[var(--tracking-tight)]">
            Need a DevOps or<br class="hidden lg:block" /> Kubernetes expert?
          </p>
        </div>

        <!-- Right: Description + CTAs -->
        <div class="flex flex-col items-start lg:items-end gap-5 lg:max-w-sm">
          <p class="text-base text-app-gray-400 leading-[1.4] tracking-[var(--tracking-tight)] lg:text-right">
            Hire me for DevOps consulting, Kubernetes setup,
            CI/CD pipelines, and Go development.
          </p>
          <div class="flex flex-wrap gap-3">
            <a
              href={socialLinks.upwork}
              target="_blank"
              rel="noopener"
              class="group inline-flex items-center gap-2 px-5 py-2.5 border border-app-gray-200 rounded-[32px] text-sm font-medium text-app-gray-500 hover:border-[#14A800] hover:text-[#14A800] transition-colors duration-300 tracking-[var(--tracking-tight)]"
            >
              <svg viewBox="0 0 512 512" xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 flex-shrink-0">
                <path d="M345.516 181.708c-42.168 0-65.774 27.481-72.532 55.773-7.658-14.416-13.335-33.698-17.75-51.628H196.94v72.531c0 26.31-11.984 45.772-35.41 45.772-23.427 0-36.852-19.462-36.852-45.772l.27-72.531H91.34v72.531c0 21.174 6.848 40.366 19.372 54.061 12.884 14.146 30.454 21.534 50.817 21.534 40.545 0 68.837-31.085 68.837-75.595V209.64c4.235 16.038 14.326 46.853 33.608 73.884l-18.02 102.625h34.148l11.893-72.712c3.875 3.244 8.02 6.127 12.434 8.74 11.443 7.208 24.508 11.263 38.023 11.713 0 0 2.073.09 3.154.09 41.807 0 75.054-32.346 75.054-76.045 0-43.7-33.337-76.226-75.144-76.226m0 122.358c-25.86 0-42.979-20.003-47.754-27.752 6.127-49.015 24.057-64.512 47.754-64.512 23.426 0 41.626 18.741 41.626 46.132 0 27.39-18.2 46.132-41.626 46.132" fill="currentColor" fill-rule="nonzero"/>
              </svg>
              Upwork
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-3 h-3 opacity-0 -translate-x-1 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300">
                <path d="M7 7h10v10"/><path d="M7 17 17 7"/>
              </svg>
            </a>
            <a
              href={socialLinks.fiverr}
              target="_blank"
              rel="noopener"
              class="group inline-flex items-center gap-2 px-5 py-2.5 border border-app-gray-200 rounded-[32px] text-sm font-medium text-app-gray-500 hover:border-[#1DBF73] hover:text-[#1DBF73] transition-colors duration-300 tracking-[var(--tracking-tight)]"
            >
              <svg viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 flex-shrink-0">
                <path d="M13.95 8.024h-5.9V6.612c0-.718.582-1.3 1.3-1.3h.65V3.6h-.65a3.016 3.016 0 0 0-3.012 3.012v1.412H4.05v1.712h2.288V13.4H8.05V9.736h5.9V8.024Z" fill="currentColor"/>
                <circle cx="12.4" cy="4.25" r="1.05" fill="currentColor"/>
              </svg>
              Fiverr
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-3 h-3 opacity-0 -translate-x-1 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300">
                <path d="M7 7h10v10"/><path d="M7 17 17 7"/>
              </svg>
            </a>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>
