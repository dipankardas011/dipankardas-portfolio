---
import { navItems, siteConfig } from "../data/site";

const currentPath = Astro.url.pathname;
---

<header class="relative z-50">
  <div class="relative z-10 container mx-auto pt-5 lg:pt-7">
    <nav class="relative flex items-center justify-between gap-4 pb-4 lg:pb-5 border-b border-app-ink-line">
      <!-- Logo / wordmark -->
      <a id="header-logo" href="/" class="flex items-center gap-2 md:flex-1 group">
        <span class="inline-block w-2 h-2 rounded-full bg-app-accent-2 group-hover:scale-125 transition-transform"></span>
        <span class="font-display font-medium text-base md:text-lg text-app-text tracking-tight group-hover:text-app-accent transition-colors">
          {siteConfig.name}
        </span>
        <span class="hidden lg:inline-block ml-2 font-mono text-[10px] uppercase tracking-[0.18em] text-app-gray-400">
          /platform-engineer
        </span>
      </a>

      <!-- Desktop nav -->
      <ul class="hidden md:flex md:flex-1 md:justify-center items-center gap-5 lg:gap-8">
        {navItems.map((item, idx) => {
          const active = currentPath === item.href || (item.href !== "/" && currentPath.startsWith(item.href));
          return (
            <li>
              <a
                href={item.href}
                class:list={[
                  "group inline-flex items-baseline gap-1.5 font-mono text-[11px] uppercase tracking-[0.16em] font-medium transition-colors duration-200",
                  active ? "text-app-text" : "text-app-gray-400 hover:text-app-text",
                ]}
              >
                <span class="text-app-accent-2 text-[9px]">
                  {String(idx + 1).padStart(2, "0")}
                </span>
                <span class="relative">
                  {item.label}
                  {active && <span class="absolute -bottom-1 left-0 right-0 h-px bg-app-accent-2"></span>}
                </span>
              </a>
            </li>
          );
        })}
      </ul>

      <!-- Right: sponsor (desktop) -->
      <div class="hidden md:flex md:flex-1 md:justify-end">
        <a
          href="https://github.com/sponsors/dipankardas011"
          target="_blank"
          rel="noopener noreferrer"
          class="group inline-flex items-center gap-2 px-4 py-2 text-xs font-mono uppercase tracking-[0.12em] font-semibold rounded-full bg-app-text text-app-body border border-app-text hover:bg-app-accent hover:border-app-accent transition-all duration-300"
        >
          <svg class="w-3.5 h-3.5 group-hover:animate-heartbeat" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
          </svg>
          Sponsor
        </a>
      </div>

      <!-- Mobile actions -->
      <div class="flex md:hidden items-center gap-3">
        <a
          href="https://github.com/sponsors/dipankardas011"
          target="_blank"
          rel="noopener noreferrer"
          class="group inline-flex items-center gap-1.5 px-3 py-1.5 text-[10px] font-mono uppercase tracking-[0.1em] font-semibold rounded-full bg-app-text text-app-body"
        >
          <svg class="w-3 h-3" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
          </svg>
          Sponsor
        </a>
        <button id="mobile-menu-btn" class="p-1.5 transition-colors" aria-label="Toggle menu">
          <svg id="menu-icon" class="w-6 h-6" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M4 8H20" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            <path d="M4 16H20" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
          <svg id="close-icon" class="w-6 h-6 hidden" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
        </button>
      </div>
    </nav>

    <!-- Mobile nav -->
    <ul id="mobile-nav-links" class="hidden flex-col gap-6 pt-12 md:hidden">
      {navItems.map((item, idx) => (
        <li>
          <a
            href={item.href}
            class:list={[
              "flex items-baseline gap-3 font-display text-2xl tracking-tight transition-colors duration-300",
              currentPath === item.href || (item.href !== "/" && currentPath.startsWith(item.href))
                ? "text-white"
                : "text-white/70 hover:text-white",
            ]}
          >
            <span class="font-mono text-xs text-app-accent-2">
              {String(idx + 1).padStart(2, "0")}
            </span>
            {item.label}
          </a>
        </li>
      ))}
    </ul>
  </div>

  <!-- Backdrop -->
  <div id="mobile-backdrop" class="hidden fixed top-0 left-0 w-screen h-screen bg-app-text md:hidden" />
</header>

<script>
  const btn       = document.getElementById("mobile-menu-btn");
  const menuIcon  = document.getElementById("menu-icon");
  const closeIcon = document.getElementById("close-icon");
  const navLinks  = document.getElementById("mobile-nav-links");
  const backdrop  = document.getElementById("mobile-backdrop");
  const logo      = document.getElementById("header-logo");

  btn?.addEventListener("click", () => {
    const isOpening = navLinks?.classList.contains("hidden");
    navLinks?.classList.toggle("hidden");
    navLinks?.classList.toggle("flex");
    backdrop?.classList.toggle("hidden");
    menuIcon?.classList.toggle("hidden");
    closeIcon?.classList.toggle("hidden");

    if (isOpening) {
      btn?.classList.add("text-white");
      logo?.classList.add("text-white");
      logo?.classList.remove("text-app-text");
    } else {
      btn?.classList.remove("text-white");
      logo?.classList.remove("text-white");
      logo?.classList.add("text-app-text");
    }
    document.body.style.overflow = isOpening ? "hidden" : "auto";
  });
</script>
