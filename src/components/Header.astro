---
import { navItems, siteConfig } from "../data/site";

const currentPath = Astro.url.pathname;
---

<header class="relative z-50">
  <div class="relative z-10 container mx-auto pt-6">
    <nav class="relative flex items-center justify-between">
      <!-- Logo -->
      <a id="header-logo" href="/" class="flex md:flex-1 text-lg md:text-xl font-display text-app-text hover:text-app-accent transition-colors tracking-tight">
        {siteConfig.name}
      </a>

      <!-- Desktop nav -->
      <ul class="hidden md:flex md:flex-1 md:justify-center items-center gap-6 lg:gap-10">
        {navItems.map((item) => (
          <li>
            <a
              href={item.href}
              class:list={[
                "text-sm md:text-base font-medium transition-colors duration-300",
                "tracking-[var(--tracking-tight)]",
                currentPath === item.href || (item.href !== "/" && currentPath.startsWith(item.href))
                  ? "text-app-text"
                  : "text-app-gray-500 hover:text-app-text",
              ]}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>

      <!-- Right section (desktop) -->
      <div class="hidden md:flex md:flex-1 md:justify-end">
        <a
          href="https://github.com/sponsors/dipankardas011"
          target="_blank"
          rel="noopener noreferrer"
          class="sponsor-btn group inline-flex items-center gap-2 px-5 py-2 text-sm font-semibold rounded-full bg-app-accent text-app-gray-500 shadow-[0_0_16px_rgba(58,67,126,0.3)] hover:shadow-[0_0_24px_rgba(58,67,126,0.5)] transition-all duration-300"
        >
          <svg class="w-4 h-4 group-hover:animate-heartbeat" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
          </svg>
          Sponsor Me
        </a>
      </div>

      <!-- Mobile sponsor + menu button -->
      <div class="flex md:hidden items-center gap-3">
        <a
          href="https://github.com/sponsors/dipankardas011"
          target="_blank"
          rel="noopener noreferrer"
          class="sponsor-btn group inline-flex items-center gap-1.5 px-3.5 py-1.5 text-xs font-semibold rounded-full bg-app-accent text-app-gray-500 shadow-[0_0_12px_rgba(58,67,126,0.3)] transition-all duration-300"
        >
          <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
          </svg>
          Sponsor
        </a>
      <button
        id="mobile-menu-btn"
        class="p-2 transition-colors"
        aria-label="Toggle menu"
      >
        <!-- 2-line hamburger (reference style) -->
        <svg id="menu-icon" class="w-6 h-6" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M4 8H20" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M4 16H20" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <!-- X icon -->
        <svg id="close-icon" class="w-6 h-6 hidden" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
      </div>
    </nav>

    <!-- Mobile nav links (sits above the backdrop, inside the z-10 container) -->
    <ul id="mobile-nav-links" class="hidden flex-col gap-8 pt-12 md:hidden">
      {navItems.map((item) => (
        <li>
          <a
            href={item.href}
            class:list={[
              "block text-base font-medium py-2 tracking-[var(--tracking-tight)] transition-colors duration-300",
              currentPath === item.href || (item.href !== "/" && currentPath.startsWith(item.href))
                ? "text-white"
                : "text-white/70 hover:text-white",
            ]}
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>
  </div>

  <!-- Full-screen dark backdrop (behind the nav via z-0) -->
  <div id="mobile-backdrop" class="hidden fixed top-0 left-0 w-screen h-screen bg-app-text md:hidden" />
</header>

<script>
  const btn = document.getElementById("mobile-menu-btn");
  const menuIcon = document.getElementById("menu-icon");
  const closeIcon = document.getElementById("close-icon");
  const navLinks = document.getElementById("mobile-nav-links");
  const backdrop = document.getElementById("mobile-backdrop");
  const logo = document.getElementById("header-logo");

  btn?.addEventListener("click", () => {
    const isOpening = navLinks?.classList.contains("hidden");

    navLinks?.classList.toggle("hidden");
    navLinks?.classList.toggle("flex");
    backdrop?.classList.toggle("hidden");
    menuIcon?.classList.toggle("hidden");
    closeIcon?.classList.toggle("hidden");

    // Switch colors for open state
    if (isOpening) {
      btn?.classList.add("text-white");
      logo?.classList.add("text-white");
      logo?.classList.remove("text-app-text");
    } else {
      btn?.classList.remove("text-white");
      logo?.classList.remove("text-white");
      logo?.classList.add("text-app-text");
    }

    document.body.style.overflow = isOpening ? "hidden" : "auto";
  });
</script>
