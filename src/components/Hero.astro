---
import { siteConfig, socialLinks } from "../data/site";
import BlurDecoration from "./BlurDecoration.astro";

const today = new Date().toISOString().slice(0, 10);
---

<section class="hero-section relative pt-6 pb-12 lg:pt-10 lg:pb-20">
  <div class="container mx-auto">

    <!-- System strip -->
    <div class="sys-strip mb-10 lg:mb-14 hero-reveal" style="--reveal-d:0">
      <span class="sys-key">~/dipankar-das</span>
      <span class="sys-dot">●</span>
      <span class="sys-value">platform-engineer</span>
      <span class="sys-dot">●</span>
      <span class="sys-value hidden sm:inline">status: open-to-collab</span>
      <span class="sys-dot hidden sm:inline">●</span>
      <span class="sys-value ml-auto">{today}</span>
    </div>

    <!-- Hero grid -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12 items-end">

      <!-- LEFT: copy block (8 cols) -->
      <div class="lg:col-span-8">
        <div class="kicker mb-5 hero-reveal" style="--reveal-d:1">Platform Engineer · Problem Solver</div>

        <h1 class="font-display font-medium text-[clamp(2.4rem,6.4vw,4.8rem)] leading-[1.02] tracking-[-0.03em] text-app-text hero-reveal" style="--reveal-d:2">
          Hi, I'm <span class="font-serif italic font-normal text-app-accent">Dipankar</span> —
          I build systems that
          <span class="relative inline-block">
            works
            <span class="absolute left-0 right-0 -bottom-1 h-[8px] bg-app-accent-2/30 -z-10"></span>
          </span>.
        </h1>

        <p class="mt-6 flex flex-wrap items-baseline gap-x-3 gap-y-1 font-mono text-[12px] tracking-[0.04em] text-app-gray-500 hero-reveal" style="--reveal-d:3">
          <span class="font-mono text-[10px] uppercase tracking-[0.18em] text-app-gray-400">principles —</span>
          <span class="text-app-text">don't fail</span>
          <span class="text-app-accent-2 font-bold">+</span>
          <span class="text-app-text">run effortless</span>
          <span class="text-app-accent-2 font-bold">+</span>
          <span class="text-app-text">stay efficient</span>
        </p>

        <p class="mt-6 lg:mt-8 max-w-xl text-base lg:text-lg leading-[1.55] text-app-gray-500 hero-reveal" style="--reveal-d:4">
          Kubernetes, Go, OpenTelemetry. Deep-dives on DevOps and distributed
          systems — efficiency is the goal, not an afterthought.
        </p>

        <!-- CTAs -->
        <div class="mt-7 flex flex-wrap gap-3 hero-reveal" style="--reveal-d:5">
          <a href="/services/" class="btn-primary">
            <span>Work with me</span>
            <span class="font-mono text-xs">→</span>
          </a>
          <a href="/blog/" class="btn-ghost">
            <span>Read the blog</span>
            <span class="font-mono text-xs">↘</span>
          </a>
          <a href={siteConfig.resumeUrl} target="_blank" rel="noopener" class="btn-ghost">
            <span>Resume</span>
            <span class="font-mono text-xs">↗</span>
          </a>
        </div>

        <!-- Social shortcut row (mono) -->
        <ul class="mt-7 flex flex-wrap items-center gap-x-5 gap-y-2 font-mono text-[11px] uppercase tracking-[0.14em] text-app-gray-400 hero-reveal" style="--reveal-d:6">
          <li><a href={socialLinks.github} target="_blank" rel="noopener" class="hover:text-app-text transition-colors">github ↗</a></li>
          <li><a href={socialLinks.linkedin} target="_blank" rel="noopener" class="hover:text-app-text transition-colors">linkedin ↗</a></li>
          <li><a href={socialLinks.twitter} target="_blank" rel="noopener" class="hover:text-app-text transition-colors">twitter ↗</a></li>
          <li><a href={socialLinks.hashnode} target="_blank" rel="noopener" class="hover:text-app-text transition-colors">hashnode ↗</a></li>
        </ul>
      </div>

      <!-- RIGHT: portrait card (4 cols) -->
      <div class="lg:col-span-4 hero-reveal" style="--reveal-d:3">
        <div class="relative">
          <BlurDecoration variant="purple" position="top-right" />
          <BlurDecoration variant="terra"  position="bottom-left" />

          <div class="relative aspect-[3/4] overflow-hidden border border-app-ink-line bg-app-surface">
            <img
              src="/img/profile_bw.webp"
              alt={siteConfig.name}
              class="w-full h-full object-cover hover:scale-[1.03] transition-transform duration-700"
              loading="eager"
            />
            <!-- corner crosshairs -->
            <span class="absolute top-2 left-2 w-3 h-3 border-l border-t border-app-accent-2"></span>
            <span class="absolute top-2 right-2 w-3 h-3 border-r border-t border-app-accent-2"></span>
            <span class="absolute bottom-2 left-2 w-3 h-3 border-l border-b border-app-accent-2"></span>
            <span class="absolute bottom-2 right-2 w-3 h-3 border-r border-b border-app-accent-2"></span>
          </div>

          <!-- caption strip -->
          <div class="mt-3 flex items-center justify-between font-mono text-[10px] uppercase tracking-[0.16em] text-app-gray-400">
            <span>fig.01 / portrait</span>
            <span class="text-app-accent">live</span>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  /*
   * Full-viewport hero on large screens.
   * On small screens content can exceed viewport — min-height ensures
   * it grows naturally instead of clipping.
   */
  .hero-section {
    min-height: calc(100svh - 5rem); /* 5rem ≈ header + border */
  }

  /* Staggered reveal animation for hero elements */
  @keyframes hero-reveal-up {
    from {
      opacity: 0;
      transform: translateY(18px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .hero-reveal {
    opacity: 0;
    animation: hero-reveal-up 0.7s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: calc(var(--reveal-d, 0) * 0.1s + 0.15s);
  }

  /* Respect reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .hero-reveal {
      opacity: 1;
      animation: none;
      transform: none;
    }
  }
</style>
