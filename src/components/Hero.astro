---
import { siteConfig, socialLinks } from "../data/site";
import BlurDecoration from "./BlurDecoration.astro";

const today = new Date().toISOString().slice(0, 10);
---

<section class="relative pt-6 pb-12 lg:pt-10 lg:pb-20 animate-fade-in">
  <div class="container mx-auto">

    <!-- System strip -->
    <div class="sys-strip mb-10 lg:mb-14">
      <span class="sys-key">~/dipankar-das</span>
      <span class="sys-dot">●</span>
      <span class="sys-value">platform-engineer</span>
      <span class="sys-dot">●</span>
      <span class="sys-value hidden sm:inline">status: open-to-collab</span>
      <span class="sys-dot hidden sm:inline">●</span>
      <span class="sys-value ml-auto">{today}</span>
    </div>

    <!-- Hero grid -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12 items-end">

      <!-- LEFT: copy block (8 cols) -->
      <div class="lg:col-span-8">
        <div class="kicker mb-6">Engineering systems that don't break at 3am</div>

        <h1 class="font-display font-medium text-[clamp(2.6rem,7vw,5.6rem)] leading-[0.98] tracking-[-0.03em] text-app-text">
          Hi — I'm <span class="font-serif italic font-normal text-app-accent">Dipankar</span>,<br/>
          a platform engineer<br/>
          building the boring,<br/>
          load-bearing layer<br/>
          <span class="relative inline-block">
            of the internet
            <span class="absolute left-0 right-0 -bottom-2 h-[10px] bg-app-accent-2/30 -z-10"></span>
          </span>.
        </h1>

        <p class="mt-8 lg:mt-10 max-w-xl text-base lg:text-lg leading-[1.55] text-app-gray-500">
          I run on Kubernetes, Go, and OpenTelemetry. I write deep-dives on
          DevOps, distributed systems, and the unglamorous work that keeps
          your services up — so your developers don't have to think about it.
        </p>

        <!-- CTAs -->
        <div class="mt-10 flex flex-wrap gap-3">
          <a href="/services/" class="btn-primary">
            <span>Work with me</span>
            <span class="font-mono text-xs">→</span>
          </a>
          <a href="/blog/" class="btn-ghost">
            <span>Read the blog</span>
            <span class="font-mono text-xs">↘</span>
          </a>
          <a href={siteConfig.resumeUrl} target="_blank" rel="noopener" class="btn-ghost">
            <span>Resume</span>
            <span class="font-mono text-xs">↗</span>
          </a>
        </div>

        <!-- Social shortcut row (mono) -->
        <ul class="mt-10 flex flex-wrap items-center gap-x-5 gap-y-2 font-mono text-[11px] uppercase tracking-[0.14em] text-app-gray-400">
          <li><a href={socialLinks.github} target="_blank" rel="noopener" class="hover:text-app-text transition-colors">github ↗</a></li>
          <li><a href={socialLinks.linkedin} target="_blank" rel="noopener" class="hover:text-app-text transition-colors">linkedin ↗</a></li>
          <li><a href={socialLinks.twitter} target="_blank" rel="noopener" class="hover:text-app-text transition-colors">twitter ↗</a></li>
          <li><a href={socialLinks.hashnode} target="_blank" rel="noopener" class="hover:text-app-text transition-colors">hashnode ↗</a></li>
        </ul>
      </div>

      <!-- RIGHT: portrait card (4 cols) -->
      <div class="lg:col-span-4">
        <div class="relative">
          <BlurDecoration variant="purple" position="top-right" />
          <BlurDecoration variant="terra"  position="bottom-left" />

          <div class="relative aspect-[3/4] overflow-hidden border border-app-ink-line bg-app-surface">
            <img
              src={siteConfig.profileImage}
              alt={siteConfig.name}
              class="w-full h-full object-cover grayscale-[20%] hover:grayscale-0 transition-all duration-700"
              loading="eager"
            />
            <!-- corner crosshairs -->
            <span class="absolute top-2 left-2 w-3 h-3 border-l border-t border-app-accent-2"></span>
            <span class="absolute top-2 right-2 w-3 h-3 border-r border-t border-app-accent-2"></span>
            <span class="absolute bottom-2 left-2 w-3 h-3 border-l border-b border-app-accent-2"></span>
            <span class="absolute bottom-2 right-2 w-3 h-3 border-r border-b border-app-accent-2"></span>
          </div>

          <!-- caption strip -->
          <div class="mt-3 flex items-center justify-between font-mono text-[10px] uppercase tracking-[0.16em] text-app-gray-400">
            <span>fig.01 / portrait</span>
            <span class="text-app-accent">live</span>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
