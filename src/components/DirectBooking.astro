---
import { siteConfig, socialLinks } from "../data/site";

const checkoutUrl = import.meta.env.PUBLIC_POLAR_CHECKOUT_URL;

const quickServices = [
  {
    name: "CI/CD Pipeline Setup",
    price: "$50",
    description: "GitHub Actions, ArgoCD, or Jenkins pipeline for your project",
    icon: "rocket",
  },
  {
    name: "Dockerfile & K8s Manifests",
    price: "$50",
    description: "Production-ready containerization with Kubernetes deployment configs",
    icon: "container",
  },
  {
    name: "Infrastructure Review",
    price: "$100",
    description: "Audit your cloud infra, Terraform, or Helm charts with actionable fixes",
    icon: "search",
  },
  {
    name: "System Design Session",
    price: "$150",
    description: "1-on-1 session to architect your distributed system or platform",
    icon: "design",
  },
  {
    name: "1-on-1 Consultation",
    price: "$5",
    description: "Quick call for debugging, code review, or technical questions",
    icon: "call",
  },
];

const iconPaths: Record<string, string> = {
  rocket: "M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5 M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09 M9 12a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.4 22.4 0 0 1-4 2z M9 12H4s.55-3.03 2-4c1.62-1.08 5 .05 5 .05",
  container: "M22 8.5V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v2.5 M2 12h20 M22 15.5V18a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2v-2.5 M2 8.5h20 M6 16h.01 M10 16h.01",
  search: "M11 3a8 8 0 1 0 0 16 8 8 0 0 0 0-16z M21 21l-4.35-4.35 M11 8v6 M8 11h6",
  design: "M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z",
  call: "M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z",
};
---

<section class="py-16 lg:py-24 border-t border-app-ink-line">
  <div class="container mx-auto">

    <div class="sys-strip mb-12 lg:mb-16">
      <span class="sys-key">~/work-with-me</span>
      <span class="sys-dot">●</span>
      <span class="sys-value">direct booking</span>
      <span class="sys-dot">●</span>
      <span class="sys-value">no platform fees</span>
      <span class="sys-dot">●</span>
      <span class="sys-value ml-auto flex items-center gap-2">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-app-accent opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-app-accent"></span>
        </span>
        available now
      </span>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 mb-12 lg:mb-16 items-end">
      <div class="lg:col-span-8">
        <div class="kicker mb-5">/direct booking</div>
        <h2 class="font-display text-3xl md:text-5xl lg:text-6xl text-app-text tracking-tight leading-[1.02]">
          Work with me<br/>
          <span class="font-serif italic font-normal text-app-accent">directly</span>.
        </h2>
        <p class="mt-6 max-w-xl text-base lg:text-lg text-app-gray-500 leading-[1.55]">
          Skip the platform fees. Pick a fixed-scope service below or request
          a custom project — no middleman, no markup.
        </p>
      </div>

      <aside class="lg:col-span-4 lg:pl-8 lg:border-l border-app-border">
        <div class="kicker mb-3">/prefer platforms</div>
        <div class="flex flex-wrap gap-2">
          <a
            href={socialLinks.upwork}
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-2 px-3 py-2 border border-app-border bg-app-body font-mono text-[11px] uppercase tracking-[0.12em] text-app-gray-500 hover:border-[#14A800] hover:text-[#14A800] transition-colors"
          >
            <svg viewBox="0 0 512 512" xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 flex-shrink-0">
              <path d="M345.516 181.708c-42.168 0-65.774 27.481-72.532 55.773-7.658-14.416-13.335-33.698-17.75-51.628H196.94v72.531c0 26.31-11.984 45.772-35.41 45.772-23.427 0-36.852-19.462-36.852-45.772l.27-72.531H91.34v72.531c0 21.174 6.848 40.366 19.372 54.061 12.884 14.146 30.454 21.534 50.817 21.534 40.545 0 68.837-31.085 68.837-75.595V209.64c4.235 16.038 14.326 46.853 33.608 73.884l-18.02 102.625h34.148l11.893-72.712c3.875 3.244 8.02 6.127 12.434 8.74 11.443 7.208 24.508 11.263 38.023 11.713 0 0 2.073.09 3.154.09 41.807 0 75.054-32.346 75.054-76.045 0-43.7-33.337-76.226-75.144-76.226m0 122.358c-25.86 0-42.979-20.003-47.754-27.752 6.127-49.015 24.057-64.512 47.754-64.512 23.426 0 41.626 18.741 41.626 46.132 0 27.39-18.2 46.132-41.626 46.132" fill="currentColor" fill-rule="nonzero"/>
            </svg>
            Upwork
          </a>
          <a
            href={socialLinks.fiverr}
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-2 px-3 py-2 border border-app-border bg-app-body font-mono text-[11px] uppercase tracking-[0.12em] text-app-gray-500 hover:border-app-accent hover:text-app-accent transition-colors"
          >
            <svg viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 flex-shrink-0">
              <path d="M13.95 8.024h-5.9V6.612c0-.718.582-1.3 1.3-1.3h.65V3.6h-.65a3.016 3.016 0 0 0-3.012 3.012v1.412H4.05v1.712h2.288V13.4H8.05V9.736h5.9V8.024Z" fill="currentColor"/>
              <circle cx="12.4" cy="4.25" r="1.05" fill="currentColor"/>
            </svg>
            Fiverr
          </a>
        </div>
      </aside>
    </div>

    {/* Quick Services Grid */}
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 lg:gap-5 mb-8 lg:mb-10">
      {quickServices.map((service) => {
        const isDirectCheckout = !!checkoutUrl;
        const Tag = isDirectCheckout ? "a" : "button";
        const props = isDirectCheckout ? {
          href: checkoutUrl,
          target: "_blank",
          rel: "noopener"
        } : {
          "data-service": service.name,
          class: "open-contact-modal text-left w-full",
        };

        return (
          <Tag
            {...props}
            class={`${props.class || ""} group relative bg-app-body border border-app-border px-6 py-6 lg:px-7 lg:py-7 card-hover block focus:outline-none overflow-hidden`}
          >
            <span class="absolute top-0 left-0 h-px bg-app-accent w-0 group-hover:w-full transition-[width] duration-500"></span>
            <div class="flex items-start justify-between mb-4">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 border border-app-border bg-app-surface flex items-center justify-center flex-shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="var(--color-app-accent)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-4.5 h-4.5">
                    <path d={iconPaths[service.icon]} />
                  </svg>
                </div>
                <h3 class="font-display text-base lg:text-lg text-app-text tracking-tight">{service.name}</h3>
              </div>
              <span class="font-mono text-[11px] uppercase tracking-[0.12em] font-semibold text-app-accent whitespace-nowrap ml-3">
                from {service.price}
              </span>
            </div>
            <p class="text-sm text-app-gray-500 leading-[1.55] mb-4 pl-[3.25rem]">
              {service.description}
            </p>
            <div class="flex items-center gap-1.5 pl-[3.25rem] font-mono text-[10px] uppercase tracking-[0.18em] font-semibold text-app-accent">
              <span>{checkoutUrl ? "Book now" : "Send inquiry"}</span>
              <span class="transform translate-x-0 group-hover:translate-x-1 transition-transform duration-300">→</span>
            </div>
          </Tag>
        );
      })}
    </div>

    {/* Custom Project CTA */}
    <div class="bg-app-surface border border-app-ink-line px-8 py-8 lg:px-12 lg:py-10">
      <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-6">
        <div class="flex-1">
          <div class="kicker mb-3">/custom · scoped proposal</div>
          <p class="font-display text-2xl lg:text-3xl text-app-text leading-tight tracking-tight">
            Need something <span class="font-serif italic font-normal text-app-accent">custom</span>?
          </p>
          <p class="text-base text-app-gray-500 leading-[1.55] mt-3 max-w-lg">
            Larger projects, ongoing consulting, or specialized DevOps &amp; cloud work.
            Describe your needs and I'll send a tailored proposal with pricing.
          </p>
        </div>
        <button
          data-service="Custom Project"
          class="open-contact-modal btn-primary flex-shrink-0 cursor-pointer"
        >
          <span class="font-mono text-[11px] uppercase tracking-[0.12em]">Discuss your project</span>
          <span>→</span>
        </button>
      </div>
    </div>

  </div>

  <!-- Inquiry Modal -->
  <dialog id="contactModal" class="bg-transparent p-0 m-auto backdrop:bg-black/60 backdrop:backdrop-blur-sm w-[90vw] max-w-lg" data-email={siteConfig.email}>
    <div class="bg-app-surface border border-app-gray-100 rounded-2xl w-full p-6 md:p-8 shadow-2xl relative text-left">
      <button id="closeModal" class="absolute top-4 right-4 text-app-gray-400 hover:text-app-text transition-colors p-2 rounded-full hover:bg-app-surface-alt">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
      </button>
      
      <h3 class="text-2xl font-display text-app-text mb-2">Discuss a Project</h3>
      <p class="text-sm text-app-gray-400 mb-6 leading-relaxed" id="modalDescription">Fill out the details below, and it will format an email for you to send directly to my inbox.</p>
      
      <div class="bg-app-accent/10 border border-app-accent/20 rounded-xl p-3 flex items-center gap-3 mb-4">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-app-accent flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/><path d="m9 12 2 2 4-4"/></svg>
        <span class="text-sm text-app-text font-medium tracking-[var(--tracking-tight)]">You will hear from me within 2 days.</span>
      </div>
      <div class="bg-[#29b6f6]/10 border border-[#29b6f6]/20 rounded-xl p-3 flex items-center gap-3 mb-6">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-[#29b6f6] flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
        <span class="text-sm text-app-text font-medium tracking-[var(--tracking-tight)]">Please make sure the purpose is meaningful.</span>
      </div>

      <!-- PayPal Section for Consultation -->
      <div id="consultationSection" class="hidden space-y-4">
        <div class="bg-app-accent/10 border border-app-accent/20 rounded-xl p-4">
          <p class="text-sm text-app-text font-medium mb-3">1-on-1 Consultation - $5 USD</p>
          
          <div class="flex justify-center my-3">
            <form action="https://www.paypal.com/ncp/payment/NGFNEJ6XYL6V8" method="post" target="_blank" style="display:inline-grid;justify-items:center;align-content:start;gap:0.5rem;">
              <input type="submit" value="Pay Now" style="text-align:center;border:none;border-radius:1.5rem;min-width:11.625rem;padding:0 2rem;height:2.625rem;font-weight:bold;background-color:#FFD140;color:#000000;font-family:'Helvetica Neue',Arial,sans-serif;font-size:1rem;line-height:1.25rem;cursor:pointer;" />
              <img src="https://www.paypalobjects.com/images/Debit_Credit_APM.svg" alt="cards" />
              <section style="font-size:0.75rem;">Powered by <img src="https://www.paypalobjects.com/paypal-ui/logos/svg/paypal-wordmark-color.svg" alt="paypal" style="height:0.875rem;vertical-align:middle;"/></section>
            </form>
          </div>
          
          <button id="paidBtn" type="button" class="w-full mt-3 py-2 px-4 border-2 border-dashed border-app-gray-300 hover:border-app-text hover:bg-app-surface text-app-text rounded-lg text-sm font-medium transition-colors">
            I've completed payment →
          </button>
        </div>
        
        <div id="calendarSection" class="hidden space-y-4">
          <div class="bg-yellow-50 border border-yellow-200 rounded-xl p-4">
            <p class="text-sm text-yellow-800 font-medium mb-2">Purpose: 1-on-1 Consultation</p>
            <p class="text-xs text-yellow-700">Transaction ID: Copy from your PayPal receipt</p>
          </div>
          <a 
            href="https://calendar.app.google/CEmQghoA3wCUfbSa6"
            target="_blank"
            rel="noopener"
            class="inline-flex items-center justify-center gap-2 w-full py-3 bg-app-text hover:bg-app-accent text-app-body rounded-xl font-medium text-sm transition-colors"
          >
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-5 h-5">
              <rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/>
            </svg>
            Book on Google Calendar
          </a>
        </div>
      </div>

      <!-- Standard Form -->
      <form id="contactForm" class="space-y-4">
        <input type="hidden" id="serviceName" name="serviceName" value="" />
        
        <div>
          <label for="projectName" class="block text-sm font-medium text-app-text mb-1.5">Project / Repo Name <span class="text-app-accent">*</span></label>
          <input type="text" id="projectName" class="w-full bg-app-surface-alt border border-app-gray-100 rounded-xl px-4 py-3 text-app-text focus:outline-none focus:border-app-accent focus:ring-1 focus:ring-app-accent/50 transition-all text-sm placeholder:text-app-gray-500" placeholder="e.g., Acme Corp Infra" />
        </div>
        
        <div>
          <label for="category" class="block text-sm font-medium text-app-text mb-1.5">Category <span class="text-app-accent">*</span></label>
          <div class="relative">
            <select id="category" class="w-full bg-app-surface-alt border border-app-gray-100 rounded-xl px-4 py-3 text-app-text focus:outline-none focus:border-app-accent focus:ring-1 focus:ring-app-accent/50 transition-all text-sm appearance-none cursor-pointer invalid:text-app-gray-500 disabled:opacity-80 disabled:cursor-not-allowed disabled:bg-app-surface/50">
              <option value="" disabled selected hidden>Select a category</option>
              <option value="CI/CD & Automation" class="text-app-text">CI/CD & Automation</option>
              <option value="Kubernetes & Containers" class="text-app-text">Kubernetes & Containers</option>
              <option value="Cloud Infrastructure" class="text-app-text">Cloud Infrastructure</option>
              <option value="Backend / Go Development" class="text-app-text">Backend / Go Development</option>
              <option value="System Design" class="text-app-text">System Design</option>
              <option value="1-on-1 Consultation" class="text-app-text">1-on-1 Consultation ($5)</option>
              <option value="Other" class="text-app-text">Other</option>
            </select>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none text-app-gray-400"><path d="m6 9 6 6 6-6"/></svg>
          </div>
        </div>

        <div>
          <label for="projectDetails" class="block text-sm font-medium text-app-text mb-1.5">What do you need?</label>
          <textarea id="projectDetails" rows="4" class="w-full bg-app-surface-alt border border-app-gray-100 rounded-xl px-4 py-3 text-app-text focus:outline-none focus:border-app-accent focus:ring-1 focus:ring-app-accent/50 transition-all text-sm resize-none placeholder:text-app-gray-500" placeholder="Describe your current setup and desired outcome..."></textarea>
        </div>
        
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label for="timeline" class="block text-sm font-medium text-app-text mb-1.5">Timeline</label>
            <div class="relative">
              <select id="timeline" class="w-full bg-app-surface-alt border border-app-gray-100 rounded-xl px-4 py-3 text-app-text focus:outline-none focus:border-app-accent focus:ring-1 focus:ring-app-accent/50 transition-all text-sm appearance-none cursor-pointer invalid:text-app-gray-500">
                <option value="" disabled selected hidden>Select</option>
                <option value="ASAP" class="text-app-text">ASAP</option>
                <option value="Within 2 weeks" class="text-app-text">Within 2 weeks</option>
                <option value="Within a month" class="text-app-text">Within a month</option>
                <option value="Flexible" class="text-app-text">Flexible</option>
              </select>
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none text-app-gray-400"><path d="m6 9 6 6 6-6"/></svg>
            </div>
          </div>
          <div>
            <label for="budget" class="block text-sm font-medium text-app-text mb-1.5">Budget Range</label>
            <div class="relative">
              <select id="budget" class="w-full bg-app-surface-alt border border-app-gray-100 rounded-xl px-4 py-3 text-app-text focus:outline-none focus:border-app-accent focus:ring-1 focus:ring-app-accent/50 transition-all text-sm appearance-none cursor-pointer invalid:text-app-gray-500">
                <option value="" disabled selected hidden>Select</option>
                <option value="Small Task (under 100)" class="text-app-text">Small Task (&lt; $100)</option>
                <option value="$100 - $500" class="text-app-text">$100 - $500</option>
                <option value="$500 - $1k" class="text-app-text">$500 - $1,000</option>
                <option value="$1k - $5k" class="text-app-text">$1,000 - $5,000</option>
                <option value="$5k+" class="text-app-text">$5,000+</option>
              </select>
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none text-app-gray-400"><path d="m6 9 6 6 6-6"/></svg>
            </div>
          </div>
        </div>
        
        <div class="pt-6 mt-6 flex flex-col gap-3">
          <button type="submit" class="w-full bg-app-text hover:bg-opacity-90 text-white rounded-[32px] px-4 py-3.5 text-sm font-medium transition-all flex justify-center items-center gap-2 group border border-transparent">
            <span>Send</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transform group-hover:translate-x-1 group-hover:-translate-y-1 transition-transform">
              <path d="M14.536 21.686a.5.5 0 0 0 .937-.024l6.5-19a.496.496 0 0 0-.635-.635l-19 6.5a.5.5 0 0 0-.024.937l7.93 3.18a2 2 0 0 1 1.112 1.11z"/>
              <path d="m21.854 2.147-10.94 10.939"/>
            </svg>
          </button>
        </div>
      </form>
    </div>
  </dialog>
</section>

<script>
  function setupModal() {
    const modal = document.getElementById('contactModal') as HTMLDialogElement;
    if (!modal) return;
    
    const closeBtn = document.getElementById('closeModal');
    const form = document.getElementById('contactForm') as HTMLFormElement;
    const serviceInput = document.getElementById('serviceName') as HTMLInputElement;
    const modalDesc = document.getElementById('modalDescription');
    const contactButtons = document.querySelectorAll('.open-contact-modal');
    const categorySelect = document.getElementById('category') as HTMLSelectElement;
    
    const emailAddress = modal.dataset.email || 'hello@example.com';
    const consultationSection = document.getElementById('consultationSection');
    const calendarSection = document.getElementById('calendarSection');
    const paidBtn = document.getElementById('paidBtn');
    
    paidBtn?.addEventListener('click', () => {
      calendarSection?.classList.remove('hidden');
      paidBtn.classList.add('hidden');
    });
    
    categorySelect?.addEventListener('change', () => {
      const isConsultation = categorySelect.value.includes('Consultation');
      consultationSection?.classList.toggle('hidden', !isConsultation);
      form.classList.toggle('hidden', isConsultation);
    });
    
    const serviceCategoryMap: Record<string, string> = {
      "CI/CD Pipeline Setup": "CI/CD & Automation",
      "Dockerfile & K8s Manifests": "Kubernetes & Containers",
      "Infrastructure Review": "Cloud Infrastructure",
      "System Design Session": "System Design",
      "1-on-1 Consultation": "1-on-1 Consultation"
    };
    
    contactButtons.forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        const service = btn.getAttribute('data-service') || 'Custom Project';
        serviceInput.value = service;
        
        if (service === '1-on-1 Consultation') {
          consultationSection?.classList.remove('hidden');
          form.classList.add('hidden');
          if (modalDesc) modalDesc.textContent = "Book your 1-on-1 consultation session.";
          if (categorySelect) categorySelect.disabled = true;
        } else {
          consultationSection?.classList.add('hidden');
          form.classList.remove('hidden');
          if (modalDesc) {
            if (service === 'Custom Project') {
               modalDesc.textContent = "Tell me about your project, goals, and what you need help with. I'll get back to you with a tailored proposal.";
               if (categorySelect) {
                 categorySelect.value = "";
                 categorySelect.disabled = false;
               }
            } else {
               modalDesc.textContent = `You are inquiring about the "${service}" service. Fill out the details below so I can get back to you quickly!`;
               if (categorySelect && serviceCategoryMap[service]) {
                 categorySelect.value = serviceCategoryMap[service];
                 categorySelect.disabled = true;
               }
            }
          }
        }
        
        document.body.style.overflow = 'hidden';
        modal.showModal();
      });
    });
    
    const closeModal = () => {
      document.body.style.overflow = '';
      modal.close();
    }
    
    closeBtn?.addEventListener('click', closeModal);
    
    modal.addEventListener('click', (e) => {
      const dialogDimensions = modal.getBoundingClientRect()
      if (
        e.clientX < dialogDimensions.left ||
        e.clientX > dialogDimensions.right ||
        e.clientY < dialogDimensions.top ||
        e.clientY > dialogDimensions.bottom
      ) {
        closeModal();
      }
    });
    
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const category = (document.getElementById('category') as HTMLSelectElement).value;
      
      const service = serviceInput.value;
      const project = (document.getElementById('projectName') as HTMLInputElement).value;
      const details = (document.getElementById('projectDetails') as HTMLTextAreaElement).value;
      const timeline = (document.getElementById('timeline') as HTMLSelectElement).value;
      const budget = (document.getElementById('budget') as HTMLSelectElement).value;
      
      const subject = encodeURIComponent(`Inquiry: ${service} - ${project}`);
      const body = encodeURIComponent(
        `Hi Dipankar,\n\nI'd like to discuss the following project with you.\n\n` +
        `--- Project Details ---\n` +
        `Service: ${service}\n` +
        `Project Name: ${project}\n` +
        `Category: ${category}\n\n` +
        `What I need:\n${details}\n\n` +
        `Timeline: ${timeline}\n` +
        `Budget Range: ${budget}\n\n` +
        `-----------------------\n\n` +
        `Looking forward to hearing from you.\n\nThanks!`
      );
      
      window.location.href = `mailto:${emailAddress}?subject=${subject}&body=${body}`;
      
      form.reset();
      closeModal();
    });
  }

  setupModal();
  document.addEventListener('astro:page-load', setupModal);
</script>

<style>
  dialog[open] {
    animation: zoom-in 0.25s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  
  dialog::backdrop {
    animation: fade-in 0.25s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    background-color: rgba(0, 0, 0, 0.4);
    backdrop-filter: blur(2px);
  }

  @keyframes zoom-in {
    from { opacity: 0; transform: scale(0.96) translateY(10px); }
    to { opacity: 1; transform: scale(1) translateY(0); }
  }

  @keyframes fade-in {
    from { opacity: 0; }
    to { opacity: 1; }
  }
</style>
