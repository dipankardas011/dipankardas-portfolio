---
import SectionHeader from "./SectionHeader.astro";
import type { Testimonial } from "../data/testimonials";

interface Props {
  testimonials: Testimonial[];
}

const { testimonials } = Astro.props;

// Shuffle helper for visual variety across columns
function shuffle<T>(arr: T[], seed: number): T[] {
  const a = [...arr];
  for (let i = a.length - 1; i > 0; i--) {
    const j = (seed * (i + 1)) % (i + 1);
    [a[i], a[j]] = [a[j], a[i]];
  }
  return a;
}

const col1 = testimonials;
const col2 = shuffle(testimonials, 3);
const col3 = shuffle(testimonials, 7);
---

<section class="pb-10 lg:pb-14">
  <div class="relative container mx-auto">
    <div class="relative z-10 mb-8 lg:mb-10">
      <div class="md:flex md:items-start md:justify-between md:gap-16 lg:gap-20 mb-8 lg:mb-10">
        <SectionHeader
          title="Testimonials"
          subtitle=""
          className="mb-0 md:mt-4"
        />
        <div class="md:max-w-[761px]">
          <p class="text-sm leading-[1.4] tracking-[var(--tracking-tight)] text-app-gray-400 lg:text-base lg:leading-[1.4]">
            What people I've worked with have to say about my work and contributions to their projects.
          </p>
        </div>
      </div>

      <div class="testimonial-columns flex justify-center gap-6 max-h-[680px] overflow-hidden">
        {[
          { items: col1, speed: '40s', class: '' },
          { items: col2, speed: '48s', class: 'hidden md:block' },
          { items: col3, speed: '44s', class: 'hidden lg:block' },
        ].map(({ items, speed, class: cls }) => (
          <div class={`flex-1 max-w-sm ${cls}`}>
            <div class="testimonial-scroll flex flex-col gap-6 pb-6" style={`--scroll-speed: ${speed}`}>
              {/* Duplicate items for seamless infinite scroll */}
              {[...items, ...items].map((item, i) => (
                <div class="p-6 lg:p-7 border border-app-border bg-app-body" key={i}>
                  <p class="text-sm leading-[1.5] tracking-[var(--tracking-tight)] text-app-gray-400 lg:text-[15px] lg:leading-[1.5]">
                    {item.content}
                  </p>
                  <div class="flex items-center justify-between mt-5">
                    <div class="flex items-center">
                      <img
                        src={item.photo}
                        alt={item.name}
                        class="w-8 h-8 rounded-full overflow-hidden object-cover mr-2.5 lg:w-10 lg:h-10 lg:mr-3"
                        loading="lazy"
                      />
                      <div>
                        <div class="text-sm leading-none tracking-[var(--tracking-tight)] font-display lg:text-base lg:leading-none">
                          {item.name}
                        </div>
                        {item.role && item.company && (
                          <div class="text-app-gray-400 font-sans text-xs lg:text-sm mt-1">
                            {item.role} at {item.company}
                          </div>
                        )}
                      </div>
                    </div>
                    {item.linkedinUrl && (
                      <a
                        href={item.linkedinUrl}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="flex-shrink-0 ml-3 text-app-gray-400 hover:text-[#0A66C2] transition-colors duration-200"
                        aria-label={`View ${item.name}'s LinkedIn recommendation`}
                      >
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 lg:w-5 lg:h-5">
                          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                        </svg>
                      </a>
                    )}
                  </div>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Blur Decorations -->
    <div class="absolute top-[50%] -left-[10%] w-[296px] h-[296px] rounded-full opacity-20 blur-[120px] bg-blend-overlay bg-blur-yellow pointer-events-none max-md:hidden" />
    <div class="absolute top-[30%] left-0 w-[296px] h-[296px] rounded-full opacity-20 blur-[120px] bg-blend-overlay bg-blur-purple pointer-events-none max-md:hidden" />
  </div>
</section>

<style>
  .testimonial-columns {
    -webkit-mask-image: linear-gradient(to bottom, transparent, black 15%, black 85%, transparent);
    mask-image: linear-gradient(to bottom, transparent, black 15%, black 85%, transparent);
  }

  .testimonial-scroll {
    animation: scroll-up var(--scroll-speed, 40s) linear infinite;
  }

  @keyframes scroll-up {
    from {
      transform: translateY(0);
    }
    to {
      transform: translateY(-50%);
    }
  }

  /* Respect reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .testimonial-scroll {
      animation: none;
    }
    .testimonial-columns {
      max-height: none;
      overflow: visible;
      -webkit-mask-image: none;
      mask-image: none;
    }
  }
</style>
