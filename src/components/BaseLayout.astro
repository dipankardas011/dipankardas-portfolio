---
import Header from "./Header.astro";
import Footer from "./Footer.astro";
import VimMotions from "./VimMotions.astro";
import "../styles/global.css";
import { siteConfig, socialLinks } from "../data/site";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  blogPost?: boolean;
}

const {
  title = siteConfig.title,
  description = siteConfig.description,
  ogImage = "/img/bg_9.webp",
  blogPost = false,
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const ogImageUrl = new URL(ogImage, Astro.site);
---

<!doctype html>
<html lang="en" data-blog={blogPost ? "true" : null}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content={siteConfig.name} />
    <meta name="theme-color" content={blogPost ? "#0D1117" : "#FAF7F0"} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteConfig.name} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="2220" />
    <meta property="og:image:height" content="1510" />
    <meta property="og:url" content={canonicalUrl} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@DipanakarDas011" />
    <meta name="twitter:creator" content="@DipanakarDas011" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Instrument+Serif:ital@0;1&family=JetBrains+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    {blogPost && (
      <link
        href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&display=swap"
        rel="stylesheet"
      />
    )}
    {blogPost && (
      <link
        rel="stylesheet"
        href="https://cdn.jsdelivr.net/npm/katex@0.16.22/dist/katex.min.css"
        crossorigin="anonymous"
      />
    )}

    <link rel="alternate" type="application/rss+xml" title={siteConfig.name} href="/rss.xml" />
    <link rel="icon" type="image/webp" href="/favicon.webp" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <title>{title}</title>

    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-9PXLCZL052"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-9PXLCZL052');
    </script>
    <script async src="https://platform.twitter.com/widgets.js"></script>
  </head>
  <body class="bg-app-body text-app-text min-h-screen flex flex-col font-sans antialiased selection:bg-app-accent-2/30 selection:text-app-text">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
    <VimMotions />

    {blogPost && (
      <>
        <div id="mermaid-zoom-overlay" class="mermaid-zoom-overlay" hidden>
          <button type="button" class="mermaid-zoom-close" aria-label="Close diagram">×</button>
          <div class="mermaid-zoom-stage" role="dialog" aria-modal="true" aria-label="Zoomed diagram"></div>
        </div>

        <style is:global>
          .mermaid {
            position: relative;
          }
          .mermaid-zoom-trigger {
            position: absolute;
            top: 0.5rem;
            right: 0.5rem;
            z-index: 2;
            background: rgba(23, 23, 23, 0.7);
            color: #fff;
            border: 1px solid rgba(255, 255, 255, 0.15);
            border-radius: 0.375rem;
            padding: 0.25rem 0.5rem;
            font-size: 0.75rem;
            line-height: 1;
            cursor: pointer;
            opacity: 0;
            transition: opacity 0.15s ease;
          }
          .mermaid:hover .mermaid-zoom-trigger,
          .mermaid:focus-within .mermaid-zoom-trigger {
            opacity: 1;
          }
          .mermaid-zoom-trigger:hover {
            background: rgba(0, 0, 0, 0.85);
          }
          .mermaid-zoom-overlay[hidden] {
            display: none;
          }
          .mermaid-zoom-overlay {
            position: fixed;
            inset: 0;
            z-index: 9999;
            background: rgba(0, 0, 0, 0.92);
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem;
          }
          .mermaid-zoom-stage {
            width: 100%;
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: auto;
            background: #171717;
            border-radius: 0.5rem;
            padding: 2rem;
            box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.08);
          }
          .mermaid-zoom-stage svg {
            max-width: 100%;
            max-height: 100%;
            width: auto;
            height: auto;
          }
          .mermaid-zoom-close {
            position: absolute;
            top: 1rem;
            right: 1.25rem;
            background: transparent;
            border: none;
            color: #fff;
            font-size: 2.5rem;
            line-height: 1;
            cursor: pointer;
            padding: 0.25rem 0.75rem;
            border-radius: 0.375rem;
          }
          .mermaid-zoom-close:hover,
          .mermaid-zoom-close:focus-visible {
            background: rgba(255, 255, 255, 0.1);
            outline: none;
          }
          body.mermaid-zoom-open {
            overflow: hidden;
          }
        </style>

        <script is:inline>
          (function () {
            function init() {
              var overlay = document.getElementById("mermaid-zoom-overlay");
              if (!overlay) return;
              var stage = overlay.querySelector(".mermaid-zoom-stage");
              var closeBtn = overlay.querySelector(".mermaid-zoom-close");

              function open(svg) {
                if (!svg) return;
                stage.innerHTML = "";
                var clone = svg.cloneNode(true);
                clone.removeAttribute("style");
                stage.appendChild(clone);
                overlay.hidden = false;
                document.body.classList.add("mermaid-zoom-open");
                closeBtn.focus();
              }

              function close() {
                overlay.hidden = true;
                stage.innerHTML = "";
                document.body.classList.remove("mermaid-zoom-open");
              }

              closeBtn.addEventListener("click", close);
              overlay.addEventListener("click", function (e) {
                if (e.target === overlay) close();
              });
              document.addEventListener("keydown", function (e) {
                if (!overlay.hidden && e.key === "Escape") close();
              });

              function attach(container) {
                if (container.dataset.zoomReady === "1") return;
                var svg = container.querySelector("svg");
                if (!svg) return;
                container.dataset.zoomReady = "1";
                var btn = document.createElement("button");
                btn.type = "button";
                btn.className = "mermaid-zoom-trigger";
                btn.setAttribute("aria-label", "Zoom diagram");
                btn.textContent = "⤢ Zoom";
                btn.addEventListener("click", function (e) {
                  e.stopPropagation();
                  open(container.querySelector("svg"));
                });
                container.appendChild(btn);
              }

              function scan() {
                document.querySelectorAll(".mermaid").forEach(attach);
              }

              scan();
              var mo = new MutationObserver(scan);
              mo.observe(document.body, { childList: true, subtree: true });
            }

            if (document.readyState === "loading") {
              document.addEventListener("DOMContentLoaded", init);
            } else {
              init();
            }
          })();
        </script>
      </>
    )}
  </body>
</html>
